<!DOCTYPE hibernate-configuration PUBLIC
"-//Hibernate/Hibernate Configuration DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>

<session-factory>

<!-- Configuracion JDBC -->

<property name="connection.driver_class"> com.mysql.cj.jdbc.Driver </property>





<property name="connection.url">

jdbc:mysql://localhost:3306/libreria

</property>

<property name="connection.username">

root

</property>

<property name="connection.password">root</property>

<property name="connection.pool_size">

1

</property>



<property name="dialect">

org.hibernate.dialect.MySQLDialect

</property>

<!-- Mostrar SQL -->

<property name="show_sql">

true

</property>

<property name="format_sql">

true

</property>

<property name="current_session_context_class">

thread

</property>

<!-- ENTIDADES -->

<mapping class="com.rodriguez.model.Tipo"/>

<mapping class="com.rodriguez.model.Publicacion"/>

<mapping class="com.rodriguez.model.Empleado"/>

<mapping class="com.rodriguez.model.Venta"/>

<mapping class="com.rodriguez.model.Promocion"/>

<mapping class="com.rodriguez.model.Usuario"/>

<mapping class="com.rodriguez.model.UsuarioRol"/>

</session-factory>

</hibernate-configuration>